# Credenciais do banco PostgreSQL do PlanEvent.
# Copie este arquivo para ".env" (na raiz do projeto) e ajuste com os SEUS valores.
# O arquivo .env NÃO é versionado (está no .gitignore) — cada pessoa usa o seu.

DB_URL=jdbc:postgresql://localhost:5432/planevent
DB_USERNAME=postgres
DB_PASSWORD=sua_senha_do_postgres
